<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidSpect launcher foreground. Adaptive icon foreground vectors
    are 108x108 with a 36dp safe zone in the centre. We keep the mark
    inside that safe zone so the system masker doesn't crop the lens.
    Geometry matches assets/web/icon.svg exactly (scaled 64 -> 108).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Device frame: rounded square centred in the safe zone.
         x=34 y=34 size=40 -> matches icon.svg (12,12)+40 in 64-vp. -->
    <path
        android:strokeColor="#F6F8FA"
        android:strokeAlpha="0.92"
        android:strokeWidth="3.2"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M40 34 L68 34 A6 6 0 0 1 74 40 L74 68 A6 6 0 0 1 68 74 L40 74 A6 6 0 0 1 34 68 L34 40 A6 6 0 0 1 40 34 Z"/>

    <!-- Lens ring -->
    <path
        android:strokeColor="#10D689"
        android:strokeWidth="3.4"
        android:fillColor="#00000000"
        android:pathData="M54 42.5 a11.5 11.5 0 1 0 0 23 a11.5 11.5 0 1 0 0 -23 z"/>

    <!-- Focal dot -->
    <path
        android:fillColor="#10D689"
        android:pathData="M54 50 a4 4 0 1 0 0 8 a4 4 0 1 0 0 -8 z"/>
</vector>
